# .env.production - Production environment variables for the frontend
# During the Vercel deployment, Vite will read this URL and compile it into the app.
# IMPORTANT: Replace the empty value below with your real EC2 public DNS/IP (e.g. http://ec2-1-2-3-4.compute-1.amazonaws.com:5001) before deploying to production!
# Leaving it completely empty allows the app to cleanly fallback to localhost for testing.
VITE_API_URL=
